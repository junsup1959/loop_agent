{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-team-admission-receipt-v4",
  "title": "Agent-Team Admission Receipt v4",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "contract_id",
    "contract_sha256",
    "accepted",
    "reason_code",
    "model_call_permitted",
    "checks",
    "violations",
    "idempotency_key",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "receipt_id": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "minLength": 1},
    "contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "accepted": {"type": "boolean"},
    "reason_code": {"type": ["string", "null"]},
    "model_call_permitted": {"type": "boolean"},
    "checks": {
      "type": "object",
      "required": ["definition_digests", "authority", "oid", "workspace", "profile", "skills", "budget", "mcp_health", "mcp_tools", "serena_onboarding"],
      "properties": {
        "definition_digests": {"type": "boolean"},
        "authority": {"type": "boolean"},
        "oid": {"type": "boolean"},
        "workspace": {"type": "boolean"},
        "profile": {"type": "boolean"},
        "skills": {"type": "boolean"},
        "budget": {"type": "boolean"},
        "mcp_health": {"type": "boolean"},
        "mcp_tools": {"type": "boolean"},
        "serena_onboarding": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "violations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "idempotency_key": {"type": "string", "minLength": 1},
    "recorded_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"accepted": {"const": true}}, "required": ["accepted"]},
      "then": {
        "properties": {
          "reason_code": {"type": "null"},
          "model_call_permitted": {"const": true},
          "violations": {"maxItems": 0}
        }
      },
      "else": {
        "properties": {
          "reason_code": {"type": "string", "minLength": 1},
          "model_call_permitted": {"const": false},
          "violations": {"minItems": 1}
        }
      }
    }
  ],
  "additionalProperties": false
}
