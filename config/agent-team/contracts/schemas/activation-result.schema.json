{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-team-activation-result-v4",
  "title": "Agent-Team Activation Result v4",
  "type": "object",
  "required": [
    "schema_version",
    "result_id",
    "contract_id",
    "activation_id",
    "transition_id",
    "capability_id",
    "result_kind",
    "subject_oid",
    "result_oid",
    "evidence_refs",
    "mcp_usage_receipts",
    "serena_consumption_receipts",
    "format_repair_used",
    "token_accounting",
    "payload",
    "idempotency_key",
    "completed_at"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "result_id": {"type": "string", "minLength": 1},
    "contract_id": {"type": "string", "minLength": 1},
    "activation_id": {"type": "string", "minLength": 1},
    "transition_id": {"type": "string", "minLength": 1},
    "capability_id": {"enum": ["pm", "ta", "pl", "developer", "qa_sdet", "build_release", "worker", "advisory"]},
    "result_kind": {
      "enum": [
        "goal_defined",
        "work_assigned",
        "revision_submitted",
        "approved",
        "needs_rework",
        "merged",
        "merge_conflict",
        "broken_integration",
        "evidence_ready",
        "advice_ready",
        "need_more_context",
        "blocked"
      ]
    },
    "subject_oid": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "result_oid": {
      "anyOf": [
        {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        {"type": "null"}
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "mcp_usage_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["receipt_id", "server_id", "tool_id", "activation_id", "evidence_sha256"],
        "properties": {
          "receipt_id": {"type": "string", "minLength": 1},
          "server_id": {"enum": ["serena", "sequentialthinking"]},
          "tool_id": {"type": "string", "minLength": 1},
          "activation_id": {"type": "string", "minLength": 1},
          "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "serena_consumption_receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["snapshot_id", "memory_name", "memory_sha256", "consumed_at"],
        "properties": {
          "snapshot_id": {"type": "string", "minLength": 1},
          "memory_name": {"enum": ["core", "tech_stack", "suggested_commands", "conventions", "task_completion"]},
          "memory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "consumed_at": {"type": "string", "format": "date-time"}
        },
        "additionalProperties": false
      }
    },
    "format_repair_used": {"type": "boolean"},
    "token_accounting": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "repair_tokens"],
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "repair_tokens": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "payload": {"type": "object"},
    "idempotency_key": {"type": "string", "minLength": 1},
    "completed_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
