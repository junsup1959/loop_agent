{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-team-migration-manifest-v4",
  "title": "Agent-Team Overlay to AX Migration Manifest v4",
  "type": "object",
  "required": [
    "schema_version",
    "migration_id",
    "mode",
    "source",
    "target",
    "seat_mappings",
    "archived_seat_ids",
    "quarantined_activation_ids",
    "preserved_evidence_refs",
    "operations",
    "rollback_operations",
    "manifest_sha256",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "migration_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["dry-run", "apply", "verify", "rollback", "cutover"]},
    "source": {
      "type": "object",
      "required": ["layout", "topology_version", "checkout_path", "state_ref"],
      "properties": {
        "layout": {"const": "target-project-overlay"},
        "topology_version": {"type": "integer", "minimum": 1, "maximum": 3},
        "checkout_path": {"type": "string", "minLength": 1},
        "state_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "required": ["layout", "topology_id", "ax_root"],
      "properties": {
        "layout": {"const": "independent-ax"},
        "topology_id": {"const": "six-slot-v1"},
        "ax_root": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "seat_mappings": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["target_slot_key", "retained_seat_id", "absorbed_seat_ids", "legacy_slot_keys"],
        "properties": {
          "target_slot_key": {"enum": ["pm_ta", "pl", "dev_1", "dev_2", "qa_build"]},
          "retained_seat_id": {"type": "string", "minLength": 1},
          "absorbed_seat_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "legacy_slot_keys": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        },
        "additionalProperties": false
      }
    },
    "archived_seat_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "quarantined_activation_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "preserved_evidence_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "operations": {"$ref": "#/$defs/operations"},
    "rollback_operations": {"$ref": "#/$defs/operations"},
    "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ordinal", "kind", "source", "target", "source_sha256", "reversible"],
        "properties": {
          "ordinal": {"type": "integer", "minimum": 0},
          "kind": {"enum": ["copy", "create", "register", "quarantine", "verify", "cutover", "remove-owned"]},
          "source": {"type": ["string", "null"]},
          "target": {"type": "string", "minLength": 1},
          "source_sha256": {
            "anyOf": [
              {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              {"type": "null"}
            ]
          },
          "reversible": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
