{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-team-activation-contract-v4",
  "title": "Agent-Team Activation Contract v4",
  "type": "object",
  "required": [
    "schema_version",
    "contract_id",
    "activation_id",
    "target_id",
    "goal_id",
    "run_id",
    "workflow",
    "transition",
    "identity",
    "authority",
    "git",
    "workspace",
    "professional_profile",
    "skills",
    "mcp_bindings",
    "clauses",
    "budget",
    "output_schema_ref",
    "idempotency_key",
    "issued_at"
  ],
  "properties": {
    "schema_version": {"const": 4},
    "contract_id": {"$ref": "#/$defs/id"},
    "activation_id": {"$ref": "#/$defs/id"},
    "target_id": {"$ref": "#/$defs/id"},
    "goal_id": {"$ref": "#/$defs/id"},
    "run_id": {"$ref": "#/$defs/id"},
    "workflow": {
      "type": "object",
      "required": ["id", "version", "sha256"],
      "properties": {
        "id": {"const": "delivery-v4"},
        "version": {"const": "4.0.0"},
        "sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "transition": {
      "type": "object",
      "required": ["id", "from_state", "to_state", "definition_sha256"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "from_state": {"$ref": "#/$defs/id"},
        "to_state": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9_-]*$"},
        "definition_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "identity": {
      "type": "object",
      "required": [
        "slot_key",
        "slot_type",
        "seat_id",
        "worker_id",
        "worker_fingerprint",
        "capability_id",
        "elastic_lease_id",
        "agent_definition_id",
        "agent_definition_sha256",
        "parent_activation_id"
      ],
      "properties": {
        "slot_key": {"enum": ["pm_ta", "pl", "dev_1", "dev_2", "qa_build", "elastic"]},
        "slot_type": {"enum": ["fixed", "elastic"]},
        "seat_id": {"type": ["string", "null"]},
        "worker_id": {"$ref": "#/$defs/id"},
        "worker_fingerprint": {"$ref": "#/$defs/sha256"},
        "capability_id": {"enum": ["pm", "ta", "pl", "developer", "qa_sdet", "build_release", "worker", "advisory"]},
        "elastic_lease_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
        "agent_definition_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"},
        "agent_definition_sha256": {
          "anyOf": [
            {"$ref": "#/$defs/sha256"},
            {"type": "null"}
          ]
        },
        "parent_activation_id": {"type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"}
      },
      "allOf": [
        {
          "if": {"properties": {"slot_type": {"const": "elastic"}}, "required": ["slot_type"]},
          "then": {
            "properties": {
              "slot_key": {"const": "elastic"},
              "seat_id": {"type": "null"},
              "capability_id": {"enum": ["worker", "advisory"]},
              "elastic_lease_id": {"$ref": "#/$defs/id"},
              "agent_definition_id": {"type": "string", "minLength": 1},
              "agent_definition_sha256": {"$ref": "#/$defs/sha256"}
            }
          },
          "else": {
            "properties": {
              "seat_id": {"type": "string", "minLength": 1},
              "elastic_lease_id": {"type": "null"},
              "agent_definition_id": {"type": "null"},
              "agent_definition_sha256": {"type": "null"},
              "parent_activation_id": {"type": "null"}
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["approval_authorities", "merge_control", "source_write", "nested_spawn_allowed"],
      "properties": {
        "approval_authorities": {
          "type": "array",
          "items": {"$ref": "#/$defs/id"},
          "uniqueItems": true
        },
        "merge_control": {"type": "boolean"},
        "source_write": {"type": "boolean"},
        "nested_spawn_allowed": {"const": false}
      },
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "required": ["base_oid", "head_oid", "subject_oid", "integration_oid", "failure_oid"],
      "properties": {
        "base_oid": {"$ref": "#/$defs/nullable_oid"},
        "head_oid": {"$ref": "#/$defs/nullable_oid"},
        "subject_oid": {"$ref": "#/$defs/oid"},
        "integration_oid": {"$ref": "#/$defs/nullable_oid"},
        "failure_oid": {"$ref": "#/$defs/nullable_oid"}
      },
      "additionalProperties": false
    },
    "workspace": {
      "type": "object",
      "required": [
        "kind",
        "workspace_id",
        "lease_id",
        "sandbox_id",
        "cwd",
        "source_roots",
        "writable_roots",
        "protected_roots",
        "prohibited_roots",
        "binding_sha256"
      ],
      "properties": {
        "kind": {"enum": ["none", "control", "developer-worktree", "integration-worktree", "detached-review-sandbox", "contract-selected"]},
        "workspace_id": {"type": ["string", "null"]},
        "lease_id": {"type": ["string", "null"]},
        "sandbox_id": {"type": ["string", "null"]},
        "cwd": {"type": ["string", "null"]},
        "source_roots": {"$ref": "#/$defs/paths"},
        "writable_roots": {"$ref": "#/$defs/paths"},
        "protected_roots": {"$ref": "#/$defs/paths"},
        "prohibited_roots": {"$ref": "#/$defs/paths"},
        "binding_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "professional_profile": {
      "type": "object",
      "required": ["skill_id", "compiled_profile_ref", "compiled_profile_sha256", "reference_sha256s"],
      "properties": {
        "skill_id": {"const": "professional-profile-runtime"},
        "compiled_profile_ref": {"type": "string", "minLength": 1},
        "compiled_profile_sha256": {"$ref": "#/$defs/sha256"},
        "reference_sha256s": {
          "type": "array",
          "minItems": 4,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/sha256"},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version", "path", "sha256", "content_budget_chars", "mcp_prerequisites"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "version": {"$ref": "#/$defs/version"},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"},
          "content_budget_chars": {"type": "integer", "minimum": 1},
          "mcp_prerequisites": {
            "type": "array",
            "items": {"enum": ["serena", "sequentialthinking"]},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "mcp_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["binding_id", "server_id", "tool_ids", "required_use", "usage_receipt_required", "policy_sha256"],
        "properties": {
          "binding_id": {"$ref": "#/$defs/id"},
          "server_id": {"enum": ["serena", "sequentialthinking"]},
          "tool_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
          "required_use": {"type": "boolean"},
          "usage_receipt_required": {"type": "boolean"},
          "policy_sha256": {"$ref": "#/$defs/sha256"}
        },
        "additionalProperties": false
      }
    },
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version", "sha256"],
        "properties": {
          "id": {"$ref": "#/$defs/id"},
          "version": {"$ref": "#/$defs/version"},
          "sha256": {"$ref": "#/$defs/sha256"}
        },
        "additionalProperties": false
      }
    },
    "serena_onboarding": {
      "type": ["object", "null"],
      "required": ["snapshot_id", "source_oid", "policy_sha256", "memory_bindings", "consumption_receipt_required"],
      "properties": {
        "snapshot_id": {"$ref": "#/$defs/id"},
        "source_oid": {"$ref": "#/$defs/oid"},
        "policy_sha256": {"$ref": "#/$defs/sha256"},
        "memory_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "sha256"],
            "properties": {
              "name": {"enum": ["core", "tech_stack", "suggested_commands", "conventions", "task_completion"]},
              "sha256": {"$ref": "#/$defs/sha256"}
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        },
        "consumption_receipt_required": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "required": ["role_packet_limit_chars", "ratio", "ceiling_chars", "effective_limit_chars", "rendered_and_clause_chars"],
      "properties": {
        "role_packet_limit_chars": {"type": "integer", "minimum": 1},
        "ratio": {"const": 0.25},
        "ceiling_chars": {"const": 12000},
        "effective_limit_chars": {"type": "integer", "minimum": 1, "maximum": 12000},
        "rendered_and_clause_chars": {"type": "integer", "minimum": 0, "maximum": 12000}
      },
      "additionalProperties": false
    },
    "output_schema_ref": {"const": "agents/contracts/schemas/activation-result.schema.json"},
    "idempotency_key": {"type": "string", "minLength": 1},
    "issued_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "identity": {
            "properties": {"slot_type": {"const": "elastic"}},
            "required": ["slot_type"]
          }
        }
      },
      "then": {
        "properties": {
          "authority": {
            "properties": {
              "approval_authorities": {"maxItems": 0},
              "merge_control": {"const": false},
              "nested_spawn_allowed": {"const": false}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "oid": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
    "nullable_oid": {
      "anyOf": [
        {"$ref": "#/$defs/oid"},
        {"type": "null"}
      ]
    },
    "paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
